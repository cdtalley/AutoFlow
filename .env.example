OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql+asyncpg://autoflow:autoflow@localhost:5432/autoflow
SYNC_DATABASE_URL=postgresql://autoflow:autoflow@localhost:5432/autoflow
ESCALATION_CONFIDENCE_THRESHOLD=0.4
MAX_AGENT_ITERATIONS=5
APP_ENV=development
# Production: comma-separated origins (no spaces). Dev wildcard:
CORS_ORIGINS=*
# Optional: require X-API-Key on POST /api/v1/webhook (unset = no auth)
# WEBHOOK_API_KEY=your-long-random-secret
# Optional: require X-Admin-Key on DELETE /api/v1/runs/{run_id} (unset = open delete — dev only)
# AUTOFLOW_ADMIN_API_KEY=another-long-random-secret
# Rate limit on POST /webhook (slowapi). Use redis for multi-worker limits:
WEBHOOK_RATE_LIMIT=60/minute
RATE_LIMIT_STORAGE=memory
# IDEMPOTENCY_TTL_SECONDS=86400
LOG_LEVEL=INFO
