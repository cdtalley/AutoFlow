# --- API (required for live data) ---
# Base URL of the AutoFlow FastAPI backend (no trailing slash)
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Match server WEBHOOK_API_KEY so the browser can call POST /webhook and WS /ws
# (dev only — do not ship production secrets in public front-end builds)
# NEXT_PUBLIC_WEBHOOK_API_KEY=

# --- White-label & demo UI (all optional) ---
# Product name shown in header, footer, and browser title (see app/layout.tsx)
# NEXT_PUBLIC_APP_NAME=AutoFlow

# Subtitle under the name in the shell header
# NEXT_PUBLIC_APP_TAGLINE=Multi-agent inquiry automation — classify, route, respond, escalate.

# Sidebar title (e.g. "Control Center" or "Operations Console")
# NEXT_PUBLIC_CONTROL_CENTER_LABEL=Control Center

# Badge next to the product name: Demo | Staging | Production
# NEXT_PUBLIC_ENVIRONMENT_LABEL=Demo

# Accent theme for buttons, charts, hero stripe: sky | violet | teal | amber
# NEXT_PUBLIC_UI_ACCENT=sky

# Initial tab: submit | live | history
# NEXT_PUBLIC_DEFAULT_TAB=submit

# One-click sample payloads on the submit screen
# NEXT_PUBLIC_SHOW_DEMO_PRESETS=true

# Show API base URL under the tagline in the header
# NEXT_PUBLIC_SHOW_API_ENDPOINT_BADGE=true

# Footer line with optional Support / Documentation links
# NEXT_PUBLIC_SHOW_FOOTER_ATTRIBUTION=true
# NEXT_PUBLIC_SUPPORT_URL=https://example.com/support
# NEXT_PUBLIC_DOCS_URL=https://example.com/docs
